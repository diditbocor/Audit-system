let temuanCount = { cg: 0 };

function addTemuan(tab) {
  temuanCount[tab]++;
  const n = temuanCount[tab];
  const list = document.getElementById('temuan-list-' + tab);
  const empty = document.getElementById('temuan-empty-' + tab);
  if (empty) empty.style.display = 'none';

  const el = document.createElement('div');
  el.className = 'temuan-card';
  el.id = 'temuan-' + tab + '-' + n;
  el.innerHTML = `
    <div class="temuan-card-header">
      <span>Temuan #${n}</span>
      <button class="remove-temuan-btn" onclick="removeTemuan('${tab}',${n})" title="Hapus temuan">✕</button>
    </div>
    <div class="temuan-card-body">
      <div class="form-group">
        <label>Temuan Utama</label>
        <textarea id="tfinding-${tab}-${n}" placeholder="Deskripsi temuan..." style="min-height:64px;"></textarea>
      </div>
      <div class="temuan-grid-2">
        <div class="form-group">
          <label>Severity</label>
          <select id="tsev-${tab}-${n}">
            <option value="">Pilih Severity</option>
            <option value="low">🟢 Low</option>
            <option value="medium">🟡 Medium</option>
            <option value="high">🔴 High</option>
            <option value="critical">🚨 Critical</option>
          </select>
        </div>
        <div class="form-group">
          <label>Due Date</label>
          <input type="date" id="tdue-${tab}-${n}">
        </div>
      </div>
      <div class="form-group">
        <label>Rekomendasi</label>
        <textarea id="trec-${tab}-${n}" placeholder="Tindakan perbaikan yang disarankan..." style="min-height:56px;"></textarea>
      </div>
      <div class="form-group">
        <label>Upload Foto Bukti</label>
        <div class="foto-upload-area" onclick="document.getElementById('fphoto-${tab}-${n}').click()">
          <span>📷</span>
          <p>Klik untuk upload foto</p>
        </div>
        <input type="file" id="fphoto-${tab}-${n}" accept="image/*" multiple style="display:none" onchange="previewFoto(this,'fpreview-${tab}-${n}')">
        <div class="foto-preview" id="fpreview-${tab}-${n}"></div>
      </div>
    </div>
  `;
  list.appendChild(el);
}

function removeTemuan(tab, n) {
  const el = document.getElementById('temuan-' + tab + '-' + n);
  if (el) el.remove();
  const list = document.getElementById('temuan-list-' + tab);
  const empty = document.getElementById('temuan-empty-' + tab);
  if (list && list.children.length === 0 && empty) {
    empty.style.display = 'block';
  }
}

function previewFoto(input, previewId) {
  const preview = document.getElementById(previewId);
  if (!preview) return;
  Array.from(input.files).forEach(file => {
    const reader = new FileReader();
    reader.onload = e => {
      const img = document.createElement('img');
      img.src = e.target.result;
      preview.appendChild(img);
    };
    reader.readAsDataURL(file);
  });
}

// ═══════════════════════════════════════
// SAVE TO SUPABASE
// ═══════════════════════════════════════
async function saveAudit() {
  if (!supabaseClient) {
    showToast('error', '⚠️ Tidak terhubung ke database. Periksa koneksi Supabase.');
    return;
  }

  showToast('info', '💾 Menyimpan data audit...');

  const headerData = {
    kontraktor: document.getElementById('kontraktor').value,
    lokasi: document.getElementById('lokasi').value,
    shift: document.getElementById('shift').value,
    tanggal_jam: document.getElementById('tanggalJam').value,
    no_kontrak: document.getElementById('noKontrak').value,
    berlaku_sampai: document.getElementById('berlakuSampai').value,
    status_izin: document.getElementById('statusIzin').value,
    kpi_produksi: parseFloat(document.getElementById('kpiProduksi').value) || null,
    kpi_safety: parseFloat(document.getElementById('kpiSafety').value) || null,
    penalty: parseInt(document.getElementById('penalty').value) || 0,
    pic: document.getElementById('pic').value,
    catatan_umum: document.getElementById('catatanUmum').value,
    tab_aktif: 'coal_getting',
    total_skor: parseInt(document.getElementById('summaryTotal').textContent) || 0,
    created_at: new Date().toISOString()
  };

  try {
    const { data: auditRow, error: auditErr } = await supabaseClient
      .from('hrm_audits')
      .insert([headerData])
      .select()
      .single();

    if (auditErr) throw auditErr;
    const auditId = auditRow.id;

    // Save audit items
    const items = [];
    CG_ALL.forEach(id => {
      items.push({
        audit_id: auditId,
        section: 'coal_getting',
        item_code: id.toUpperCase().replace('CG', 'CG-'),
        skor: scores[id] || null,
        yn: yn[id] || null,
        catatan: document.getElementById('note-' + id)?.value || null
      });
    });

    if (items.length > 0) {
      const { error: itemErr } = await supabaseClient
        .from('hrm_audit_items')
        .insert(items);
      if (itemErr) throw itemErr;
    }

    // Save insiden
    const insidenData = {
      audit_id: auditId,
      section: 'coal_getting',
      near_miss: parseInt(document.getElementById('insiden_nm_cg').value) || 0,
      fac: parseInt(document.getElementById('insiden_fac_cg').value) || 0,
      lti: parseInt(document.getElementById('insiden_lti_cg').value) || 0,
      property_damage: document.getElementById('insiden_pd_cg').value,
      deskripsi: document.getElementById('insiden_desc_cg').value,
      tindakan: document.getElementById('insiden_action_cg').value
    };
    await supabaseClient.from('hrm_findings').insert([insidenData]);

    showToast('success', '✅ Audit berhasil disimpan! ID: ' + auditId);
  } catch(e) {
    console.error(e);
    showToast('error', '❌ Gagal simpan: ' + (e.message || 'Unknown error'));
  }
}

// ═══════════════════════════════════════
// TOAST
// ═══════════════════════════════════════
let toastTimer = null;
function showToast(type, msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast ' + type + ' show';
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { t.classList.remove('show'); }, 3500);
}

