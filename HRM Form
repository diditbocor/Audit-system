function updateStatusBadge() {
  const val = document.getElementById('statusIzin').value;
  const badge = document.getElementById('statusBadge');
  const map = {
    'aktif':       ['badge-green',  '✅ Aktif & Lengkap'],
    'akan_expired':['badge-yellow', '⚠️ Akan Expired'],
    'expired':     ['badge-red',    '❌ Expired / Bermasalah'],
    'proses':      ['badge-blue',   '🔄 Dalam Proses'],
  };
  badge.className = 'badge ' + (map[val] ? map[val][0] : 'badge-gray');
  badge.textContent = map[val] ? map[val][1] : '— Belum Dipilih';
}

