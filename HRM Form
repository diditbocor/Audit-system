function setYN(itemId, val, btnEl) {
  yn[itemId] = val;
  const parent = btnEl.parentElement;
  parent.querySelectorAll('.yn-btn').forEach(b => {
    b.className = 'yn-btn';
  });
  btnEl.classList.add('active-' + val);
}

function updateSummary() {
  let total = 0;
  let filled = 0;

  // Group scores
  let kg = 0, lg = 0, sg = 0;
  CG_ITEMS.kinerja.forEach(id => { const s = scores[id] || 0; kg += s; if (s > 0) filled++; });
  CG_ITEMS.loading.forEach(id => { const s = scores[id] || 0; lg += s; if (s > 0) filled++; });
  CG_ITEMS.safety.forEach(id => { const s = scores[id] || 0; sg += s; if (s > 0) filled++; });
  total = kg + lg + sg;

  document.getElementById('gscore-kinerja').textContent = kg + ' / 25';
  document.getElementById('gscore-loading').textContent = lg + ' / 25';
  document.getElementById('gscore-safety').textContent = sg + ' / 15';
  document.getElementById('scoreCoalGetting').textContent = total + '/' + CG_MAX;
  document.getElementById('summaryTotal').textContent = total;
  document.getElementById('summaryMax').textContent = CG_MAX;

  const pct = CG_MAX > 0 ? Math.round((total / CG_MAX) * 100) : 0;
  document.getElementById('summaryPct').textContent = pct + '%';
  document.getElementById('fillBar').style.width = (filled / CG_ALL.length * 100) + '%';

  // Grade
  let grade = '—';
  if (pct >= 90) grade = 'A';
  else if (pct >= 80) grade = 'B';
  else if (pct >= 70) grade = 'C';
  else if (pct >= 60) grade = 'D';
  else if (pct > 0) grade = 'E';
  document.getElementById('summaryGrade').textContent = grade;
}

