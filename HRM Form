<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HRM Form Audit — dibup Audit System</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
:root {
  --navy: #132257;
  --navy-dark: #0c1a40;
  --navy-mid: #1a2f6e;
  --navy-light: #243580;
  --blue-accent: #4f8ef7;
  --blue-light: #7eb3ff;
  --blue-pale: #ddeeff;
  --white: #ffffff;
  --off-white: #f4f7ff;
  --gray-light: #e8edf5;
  --gray-mid: #b8c4d8;
  --gray-text: #6b7a99;
  --green: #22c55e;
  --green-light: #dcfce7;
  --yellow: #f59e0b;
  --yellow-light: #fef3c7;
  --red: #ef4444;
  --red-light: #fee2e2;
  --orange: #f97316;
  --orange-light: #ffedd5;
  --radius: 10px;
  --radius-sm: 6px;
  --shadow: 0 2px 12px rgba(19,34,87,0.10);
  --shadow-lg: 0 8px 32px rgba(19,34,87,0.16);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Barlow', sans-serif;
  background: #e8edf5;
  color: var(--navy);
  min-height: 100vh;
}

/* ── TOP HEADER ── */
.top-header {
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy-mid) 60%, var(--navy-light) 100%);
  padding: 20px 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4px 20px rgba(19,34,87,0.3);
  position: sticky;
  top: 0;
  z-index: 100;
}
.top-header .brand {
  display: flex;
  align-items: center;
  gap: 14px;
}
.top-header .brand-icon {
  width: 44px; height: 44px;
  background: var(--blue-accent);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800; font-size: 18px;
  color: white;
  letter-spacing: -1px;
}
.top-header .brand-text h1 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 22px; font-weight: 800;
  color: white; letter-spacing: 0.5px;
}
.top-header .brand-text p {
  font-size: 11px; color: var(--blue-light);
  font-weight: 400; letter-spacing: 0.3px;
}
.top-header .header-right {
  display: flex; align-items: center; gap: 12px;
}
.db-status {
  display: flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 20px;
  padding: 5px 12px;
  font-size: 11px; color: var(--blue-light);
}
.db-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--gray-mid);
  transition: background 0.3s;
}
.db-dot.connected { background: var(--green); box-shadow: 0 0 6px var(--green); }
.db-dot.error { background: var(--red); }

.back-btn {
  background: rgba(255,255,255,0.10);
  color: white;
  border: 1px solid rgba(255,255,255,0.20);
  border-radius: 8px;
  padding: 9px 16px;
  font-family: 'Barlow', sans-serif;
  font-weight: 600; font-size: 13px;
  cursor: pointer;
  display: flex; align-items: center; gap: 6px;
  transition: all 0.2s;
  text-decoration: none;
}
.back-btn:hover { background: rgba(255,255,255,0.18); }

.save-btn {
  background: var(--blue-accent);
  color: white;
  border: none;
  border-radius: 8px;
  padding: 9px 20px;
  font-family: 'Barlow', sans-serif;
  font-weight: 600; font-size: 13px;
  cursor: pointer;
  display: flex; align-items: center; gap: 6px;
  transition: all 0.2s;
}
.save-btn:hover { background: var(--blue-light); transform: translateY(-1px); }
.save-btn:active { transform: translateY(0); }

/* ── MAIN CONTAINER ── */
.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 28px 20px 60px;
}

/* ── SECTION CARD ── */
.card {
  background: white;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 20px;
  overflow: hidden;
}
.card-header {
  background: var(--navy);
  padding: 14px 22px;
  display: flex; align-items: center; justify-content: space-between;
}
.card-header h2 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 17px; font-weight: 700;
  color: white; letter-spacing: 0.5px;
  display: flex; align-items: center; gap: 8px;
}
.card-header h2 span.icon { font-size: 16px; }
.card-body { padding: 22px; }

/* ── FORM GRID ── */
.form-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 14px;
}
.form-grid-2 { grid-template-columns: repeat(2, 1fr); }
.form-grid-3 { grid-template-columns: repeat(3, 1fr); }
.form-grid-4 { grid-template-columns: repeat(4, 1fr); }

.form-group { display: flex; flex-direction: column; gap: 5px; }
.form-group label {
  font-size: 11px; font-weight: 600;
  color: var(--gray-text); text-transform: uppercase; letter-spacing: 0.5px;
}
.form-group input,
.form-group select,
.form-group textarea {
  border: 1.5px solid var(--gray-light);
  border-radius: var(--radius-sm);
  padding: 9px 12px;
  font-family: 'Barlow', sans-serif;
  font-size: 13.5px; color: var(--navy);
  background: var(--off-white);
  transition: border-color 0.2s, box-shadow 0.2s;
  outline: none;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: var(--blue-accent);
  box-shadow: 0 0 0 3px rgba(79,142,247,0.12);
  background: white;
}
.form-group textarea { resize: vertical; min-height: 72px; }
.form-group select { cursor: pointer; }

/* ── BADGE STATUS ── */
.badge {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 11px; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.3px;
}
.badge-green { background: var(--green-light); color: #16a34a; }
.badge-yellow { background: var(--yellow-light); color: #d97706; }
.badge-red { background: var(--red-light); color: #dc2626; }
.badge-blue { background: var(--blue-pale); color: #2563eb; }
.badge-gray { background: var(--gray-light); color: var(--gray-text); }
.badge-navy { background: var(--navy); color: white; }

/* ── ISO BADGE ── */
.iso-badge {
  display: inline-flex;
  padding: 2px 7px;
  border-radius: 4px;
  font-size: 9.5px; font-weight: 700;
  letter-spacing: 0.2px;
  margin-right: 3px;
}
.iso-9001 { background: #dbeafe; color: #1d4ed8; }
.iso-14001 { background: #d1fae5; color: #065f46; }
.iso-45001 { background: #fef3c7; color: #92400e; }
.iso-smkp { background: #ede9fe; color: #5b21b6; }

/* ── TABS ── */
.tabs-wrapper {
  background: white;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
  margin-bottom: 20px;
}
.tabs-nav {
  display: flex;
  background: var(--navy-dark);
  overflow-x: auto;
  scrollbar-width: none;
  gap: 0;
}
.tabs-nav::-webkit-scrollbar { display: none; }
.tab-btn {
  flex-shrink: 0;
  padding: 14px 22px;
  background: transparent;
  border: none;
  color: var(--gray-mid);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px; font-weight: 600;
  letter-spacing: 0.5px;
  cursor: pointer;
  position: relative;
  transition: all 0.2s;
  white-space: nowrap;
  display: flex; align-items: center; gap: 7px;
}
.tab-btn:hover { color: var(--blue-light); }
.tab-btn.active {
  color: white;
  background: rgba(79,142,247,0.15);
}
.tab-btn.active::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
  background: var(--blue-accent);
  border-radius: 3px 3px 0 0;
}
.tab-btn .tab-score {
  background: rgba(79,142,247,0.2);
  color: var(--blue-light);
  border-radius: 4px;
  padding: 1px 6px;
  font-size: 11px;
}
.tab-btn.active .tab-score {
  background: var(--blue-accent);
  color: white;
}
.tab-btn .soon {
  font-size: 9px; opacity: 0.5;
  background: rgba(255,255,255,0.1);
  border-radius: 3px; padding: 1px 5px;
}

.tab-content { display: none; padding: 24px; }
.tab-content.active { display: block; }

/* ── AUDIT GROUP ── */
.audit-group {
  margin-bottom: 24px;
}
.audit-group-header {
  background: linear-gradient(90deg, var(--navy) 0%, var(--navy-mid) 100%);
  border-radius: var(--radius-sm) var(--radius-sm) 0 0;
  padding: 10px 18px;
  display: flex; align-items: center; justify-content: space-between;
}
.audit-group-header h3 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 15px; font-weight: 700;
  color: white; letter-spacing: 0.5px;
}
.group-score-pill {
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 20px;
  padding: 3px 12px;
  font-size: 12px; font-weight: 600; color: white;
}

/* ── AUDIT ITEM ── */
.audit-item {
  border: 1.5px solid var(--gray-light);
  border-top: none;
  background: white;
  padding: 16px 18px;
  transition: background 0.15s;
}
.audit-item:last-child { border-radius: 0 0 var(--radius-sm) var(--radius-sm); }
.audit-item:hover { background: var(--off-white); }

.audit-item-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 10px;
}
.audit-item-left { flex: 1; }
.audit-item-num {
  font-size: 10px; font-weight: 700;
  color: var(--blue-accent);
  letter-spacing: 0.5px;
  margin-bottom: 3px;
}
.audit-item-title {
  font-size: 13.5px; font-weight: 600;
  color: var(--navy);
  line-height: 1.4;
  margin-bottom: 6px;
}
.audit-item-iso { margin-bottom: 4px; }
.audit-item-right {
  display: flex; align-items: center; gap: 10px;
  flex-shrink: 0;
}

/* ── SKOR CONTROL ── */
.score-control {
  display: flex; align-items: center; gap: 4px;
}
.score-dots {
  display: flex; gap: 4px;
}
.score-dot {
  width: 30px; height: 30px;
  border-radius: 6px;
  border: 2px solid var(--gray-light);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700;
  cursor: pointer;
  color: var(--gray-text);
  transition: all 0.15s;
  background: white;
}
.score-dot:hover { border-color: var(--blue-accent); color: var(--blue-accent); }
.score-dot.active-1 { background: #fef2f2; border-color: #ef4444; color: #ef4444; }
.score-dot.active-2 { background: #fff7ed; border-color: #f97316; color: #f97316; }
.score-dot.active-3 { background: #fefce8; border-color: #eab308; color: #ca8a04; }
.score-dot.active-4 { background: #f0fdf4; border-color: #22c55e; color: #16a34a; }
.score-dot.active-5 { background: #eff6ff; border-color: #3b82f6; color: #2563eb; }

/* ── YA/TIDAK ── */
.yn-control { display: flex; gap: 4px; }
.yn-btn {
  padding: 5px 12px;
  border-radius: 5px;
  border: 1.5px solid var(--gray-light);
  background: white;
  font-size: 11px; font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
  color: var(--gray-text);
}
.yn-btn:hover { border-color: var(--blue-accent); color: var(--blue-accent); }
.yn-btn.active-ya { background: var(--green-light); border-color: var(--green); color: #16a34a; }
.yn-btn.active-tidak { background: var(--red-light); border-color: var(--red); color: #dc2626; }

/* ── CATATAN INPUT ── */
.audit-item-note {
  margin-top: 8px;
}
.audit-item-note input {
  width: 100%;
  border: 1.5px solid var(--gray-light);
  border-radius: 5px;
  padding: 7px 11px;
  font-family: 'Barlow', sans-serif;
  font-size: 12.5px; color: var(--navy);
  background: var(--off-white);
  outline: none;
  transition: border-color 0.2s;
}
.audit-item-note input:focus {
  border-color: var(--blue-accent);
  background: white;
}

/* ── KETERANGAN EXPAND ── */
.keterangan-toggle {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 11px; color: var(--blue-accent);
  cursor: pointer; margin-top: 4px;
  padding: 3px 0;
  background: none; border: none;
  font-family: 'Barlow', sans-serif;
  font-weight: 600;
  transition: color 0.2s;
  user-select: none;
}
.keterangan-toggle:hover { color: var(--navy); }
.keterangan-toggle .arrow { transition: transform 0.2s; font-size: 10px; }
.keterangan-toggle.open .arrow { transform: rotate(180deg); }

.keterangan-panel {
  display: none;
  margin-top: 8px;
  background: var(--off-white);
  border: 1px solid var(--gray-light);
  border-radius: 6px;
  padding: 12px;
  overflow: hidden;
}
.keterangan-panel.open { display: block; }
.keterangan-panel table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}
.keterangan-panel table th {
  background: var(--navy);
  color: white;
  padding: 6px 10px;
  text-align: left;
  font-weight: 600;
  font-size: 11px;
}
.keterangan-panel table td {
  padding: 6px 10px;
  border-bottom: 1px solid var(--gray-light);
  vertical-align: top;
  line-height: 1.4;
}
.keterangan-panel table tr:last-child td { border-bottom: none; }
.keterangan-panel table tr:nth-child(even) td { background: white; }
.skor-label {
  font-weight: 700; white-space: nowrap;
}
.skor-1 { color: #ef4444; }
.skor-2 { color: #f97316; }
.skor-3 { color: #ca8a04; }
.skor-4 { color: #16a34a; }
.skor-5 { color: #2563eb; }

/* ── INSIDEN BLOCK ── */
.insiden-block {
  border: 2px solid #fee2e2;
  border-radius: var(--radius-sm);
  margin-top: 12px;
  overflow: hidden;
}
.insiden-header {
  background: #fef2f2;
  padding: 8px 14px;
  display: flex; align-items: center; gap: 8px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px; font-weight: 700;
  color: #dc2626; letter-spacing: 0.3px;
}
.insiden-body { padding: 14px; }

/* ── TEMUAN SECTION ── */
.temuan-section { margin-top: 6px; }
.temuan-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 14px;
}
.temuan-header h3 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 16px; font-weight: 700;
  color: var(--navy); display: flex; align-items: center; gap: 7px;
}
.add-temuan-btn {
  background: var(--navy);
  color: white;
  border: none;
  border-radius: 6px;
  padding: 7px 14px;
  font-family: 'Barlow', sans-serif;
  font-weight: 600; font-size: 12px;
  cursor: pointer;
  display: flex; align-items: center; gap: 5px;
  transition: all 0.2s;
}
.add-temuan-btn:hover { background: var(--navy-mid); }

.temuan-card {
  border: 1.5px solid var(--gray-light);
  border-radius: var(--radius-sm);
  margin-bottom: 12px;
  overflow: hidden;
}
.temuan-card-header {
  background: var(--off-white);
  padding: 8px 14px;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1px solid var(--gray-light);
}
.temuan-card-header span {
  font-size: 12px; font-weight: 600; color: var(--gray-text);
}
.remove-temuan-btn {
  background: none; border: none;
  color: #ef4444; cursor: pointer; font-size: 14px;
  padding: 2px 6px; border-radius: 4px;
  transition: background 0.15s;
}
.remove-temuan-btn:hover { background: var(--red-light); }
.temuan-card-body { padding: 14px; display: grid; gap: 12px; }
.temuan-grid-2 { grid-template-columns: 1fr 1fr; gap: 12px; display: grid; }

/* ── FOTO UPLOAD ── */
.foto-upload-area {
  border: 2px dashed var(--gray-mid);
  border-radius: 6px;
  padding: 18px;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
  background: var(--off-white);
}
.foto-upload-area:hover { border-color: var(--blue-accent); background: var(--blue-pale); }
.foto-upload-area p { font-size: 12px; color: var(--gray-text); }
.foto-upload-area span { font-size: 22px; display: block; margin-bottom: 4px; }
.foto-preview {
  display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px;
}
.foto-preview img {
  width: 70px; height: 70px;
  object-fit: cover; border-radius: 5px;
  border: 1.5px solid var(--gray-light);
}

/* ── SCORE SUMMARY ── */
.score-summary-bar {
  background: var(--navy);
  border-radius: var(--radius);
  padding: 16px 22px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}
.summary-item { text-align: center; }
.summary-item .val {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 28px; font-weight: 800; color: white;
  line-height: 1;
}
.summary-item .lbl {
  font-size: 10px; color: var(--blue-light);
  text-transform: uppercase; letter-spacing: 0.4px;
  margin-top: 2px;
}
.summary-divider {
  width: 1px; height: 36px;
  background: rgba(255,255,255,0.15);
}
.summary-grade {
  background: var(--blue-accent);
  border-radius: 8px;
  padding: 8px 18px;
  text-align: center;
}
.summary-grade .grade {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 32px; font-weight: 800; color: white; line-height: 1;
}
.summary-grade .grade-lbl { font-size: 10px; color: rgba(255,255,255,0.75); margin-top: 2px; }

/* ── PROGRESS BAR ── */
.progress-wrap { margin-top: 8px; }
.progress-bg {
  background: rgba(255,255,255,0.15);
  border-radius: 4px;
  height: 6px;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 4px;
  background: linear-gradient(90deg, var(--blue-accent), var(--blue-light));
  transition: width 0.4s ease;
}

/* ── TOAST ── */
.toast {
  position: fixed; bottom: 24px; right: 24px;
  background: var(--navy-dark);
  color: white;
  padding: 12px 18px;
  border-radius: 8px;
  font-size: 13px; font-weight: 500;
  box-shadow: var(--shadow-lg);
  z-index: 999;
  transform: translateY(80px); opacity: 0;
  transition: all 0.3s;
  display: flex; align-items: center; gap: 8px;
  max-width: 320px;
}
.toast.show { transform: translateY(0); opacity: 1; }
.toast.success { border-left: 4px solid var(--green); }
.toast.error { border-left: 4px solid var(--red); }
.toast.info { border-left: 4px solid var(--blue-accent); }

/* ── STATUS BADGE AUTO ── */
.status-select-wrap { position: relative; }

/* ── DIVIDER ── */
.section-divider {
  height: 1px;
  background: var(--gray-light);
  margin: 20px 0;
}

/* ── KELENGKAPAN ADMIN ── */
.admin-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}
.admin-item {
  display: flex; align-items: center; gap: 8px;
  padding: 9px 12px;
  border-radius: 6px;
  border: 1.5px solid var(--gray-light);
  font-size: 12.5px;
}
.admin-item input[type="checkbox"] {
  width: 15px; height: 15px;
  accent-color: var(--blue-accent);
  cursor: pointer;
  flex-shrink: 0;
}

/* ── KPI ROW ── */
.kpi-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}
.kpi-item {
  background: var(--off-white);
  border: 1px solid var(--gray-light);
  border-radius: 7px;
  padding: 10px 12px;
}
.kpi-item label {
  font-size: 10px; color: var(--gray-text);
  text-transform: uppercase; letter-spacing: 0.4px;
  font-weight: 600; display: block; margin-bottom: 5px;
}
.kpi-item .kpi-val {
  display: flex; align-items: center; gap: 6px;
}
.kpi-item input {
  flex: 1; min-width: 0;
  border: 1px solid var(--gray-light);
  border-radius: 4px;
  padding: 5px 8px;
  font-size: 13px; color: var(--navy);
  background: white;
  outline: none;
}
.kpi-item .unit {
  font-size: 11px; color: var(--gray-text); flex-shrink: 0;
}

@media (max-width: 768px) {
